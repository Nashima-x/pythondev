   "source": [
    "def next_age(age):\n",
    "    ret = age + 1\n",
    "    return ret\n",
    "\n",
    "name = input(\"名前を入力してください：\")\n",
    "age = input(\"現在の年齢を入力してください：\")\n",
    "age = int(age)\n",
    "\n",
    "n_age = next_age(age)\n",
    "print (f\"私の名前は {name} です。来年で {n_age} 歳になります。\")\n"
   ]
  }
