     "text": [
      "送料として350円かかります\n",
      "送料込みの価格は2,330円です。\n"
     ]
    }
   ],
   "source": [
    "net = int(input(\"税抜き価格を入力してください：\"))\n",
    "\n",
    "gross = round(net * 1.1)\n",
    "\n",
    "if gross >=2000:\n",
    "    print(\"送料は無料です\")\n",
    "    print(f\"送料込みの価格は{gross:,}円です。\")\n",
    "\n",
    "else:\n",
    "    print(\"送料として350円かかります\")\n",
    "    total = gross + 350\n",
    "    print(f\"送料込みの価格は{total:,}円です。\")\n",
    "\n",
    "\n"
   ]
  }
 ],
